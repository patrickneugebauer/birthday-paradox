FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine AS build
WORKDIR /root

ADD loops.csproj .
ADD Program.cs .

RUN dotnet publish -c Release \
    -r linux-musl-x64 \
    --self-contained true \
    -p:PublishSingleFile=true \
    -p:PublishTrimmed=true \
    -o ./publish

ENTRYPOINT ["./publish/loops"]
