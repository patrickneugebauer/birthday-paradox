FROM alpine

RUN apk add --no-cache wget clang
RUN wget -q -O scala-cli.gz  https://github.com/Virtuslab/scala-cli/releases/latest/download/scala-cli-x86_64-pc-linux-static.gz && gunzip scala-cli.gz && \
    chmod +x scala-cli && \
    mv scala-cli /usr/bin/

WORKDIR /app

COPY Loops.scala .
RUN scala-cli --power package Loops.scala --native -o loops

ENTRYPOINT ["./loops"]
