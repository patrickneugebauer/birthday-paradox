FROM gcr.io/distroless/cc-debian12
# ENV PYTHONUNBUFFERED=1
COPY --from=build /opt/pyrun /opt/pyrun
COPY --from=build /lib/x86_64-linux-gnu/libz.so.1 /lib/x86_64-linux-gnu/libz.so.1
WORKDIR /app
COPY loops.py .
# Distroless has no shell, so use the full path in EXEC form
ENTRYPOINT ["/opt/pyrun/bin/pyrun3.12", "loops.py"]
