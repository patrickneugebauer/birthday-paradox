FROM debian:stable-slim AS build

RUN apt-get update && apt-get install -y --no-install-recommends \
  wget ca-certificates xz-utils zlib1g \
  && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/pyrun && \
  wget -qO- https://github.com/eGenix/egenix-pyrun/releases/download/egenix-pyrun-2.6.0/egenix-pyrun-2.6.0-py3.12_ucs4-linux-x86_64.tgz | tar -xzC /opt/pyrun

# FROM debian:stable-slim
